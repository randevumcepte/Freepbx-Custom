# === Asterisk ARI ===
ARI_URL=http://127.0.0.1:8088
ARI_USER=admin
ARI_PASS=degistir_beni
ARI_APP=randevu_ai

# External Media: Asterisk sesi bu host:port'a RTP (slin16, 16kHz) olarak gonderir.
# Node RTP sunucusu burayi dinler.
EXTERNAL_MEDIA_HOST=127.0.0.1
EXTERNAL_MEDIA_PORT=5001

# === Claude (Anthropic) ===
# ANTHROPIC_API_KEY set degilse `ant auth login` profili de kullanilabilir.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# === Google Cloud Speech (streaming STT) ===
# Servis hesabi JSON yolu
GOOGLE_APPLICATION_CREDENTIALS=/var/lib/asterisk/agi-bin/randevu-ai/gcloud-key.json
STT_LANGUAGE=tr-TR

# === Laravel randevu API ===
API_BASE=https://app.randevumcepte.com.tr

# === TTS ===
# tts motoru: "polly" (mevcut /opt/aws-nodejs/polly.js ile ayni) veya "google"
TTS_ENGINE=polly
# Uretilen ses dosyalarinin Asterisk'in okuyabildigi dizin (ARI Playback icin)
TTS_OUT_DIR=/var/spool/asterisk/monitor
